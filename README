скрипт для бесконечного подключения к наушникам и рестарта видео для смены аудиовыхода
nano /home/pi/bt_reconnect.sh
#!/bin/bash
MAC="41:42:19:98:2D:B7"
SERVICE="VictoriasSecret.service"

# Флаг, чтобы понимать, были ли мы подключены в прошлый раз
WAS_CONNECTED=false

while true; do
    # Проверяем статус подключения
    if bluetoothctl info $MAC | grep -q "Connected: yes"; then
        # Если только что подключились (были False, стали True)
        if [ "$WAS_CONNECTED" = false ]; then
            echo "Headphones connected! Restarting $SERVICE..."
            sudo systemctl restart $SERVICE
            WAS_CONNECTED=true
        fi
    else
        # Если связи нет
        if [ "$WAS_CONNECTED" = true ]; then
            echo "Headphones lost. Switching back to speaker (Restarting $SERVICE)..."
            sudo systemctl restart $SERVICE
            WAS_CONNECTED=false
        fi
        
        # Пытаемся подключиться, если не подключены
        echo "Attempting to connect to $MAC..."
        bluetoothctl connect $MAC
    fi
    
    sleep 10
done


chmod +x /home/pi/bt_reconnect.sh
sudo nano /etc/rc.local
/home/pi/bt_reconnect.sh &
