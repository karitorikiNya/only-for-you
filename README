[Unit]
Description=lovely love
After=network.target
[Service]
User=pi #
Group=pi #
Environment=XDG_RUNTIME_DIR=/run/user/1000 #
ExecStart=/usr/bin/python3 /home/pi/only-for-you/player.py
WorkingDirectory=/home/pi/only-for-you
Restart=always
[Install]
WantedBy=multi-user.target

